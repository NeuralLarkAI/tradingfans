# ============================================================
# TradingFans — Environment Variables
# Copy to .env and fill in real values.
# ⚠️  NEVER commit .env to version control.
# ============================================================

# ── Required ─────────────────────────────────────────────────

# Polymarket EOA private key (hex string, with or without 0x prefix)
POLY_PRIVATE_KEY=""

# Polymarket funder address — the wallet that holds USDC collateral
POLY_FUNDER=""

# OpenAI API key — used for post-trade commentary only (not trade decisions)
OPENAI_API_KEY=""

# ── Optional — trading behaviour ─────────────────────────────

# Maximum USDC per order (default: 10)
POLY_MAX_SIZE="10"

# Chain: 137 = Polygon mainnet (default), 80002 = Amoy testnet
POLY_CHAIN_ID="137"

# Set to 1 to log trades without placing real orders
POLY_DRY_RUN="0"

# Restrict to a single asset: BTC, ETH, or both (default)
POLY_SYMBOL="both"

# Seconds between market scan cycles (default: 5)
POLY_POLL_INTERVAL="5"

# ── Optional — AI commentary ──────────────────────────────────

# OpenAI model used for post-trade narration (default: gpt-4.1-mini)
OPENAI_MODEL="gpt-4.1-mini"
